# Production environment variables for the React app
# Copy to .env.production and adjust as needed.
# Create React App exposes vars prefixed with REACT_APP_

# Base path for API requests. If frontend is served by the same FastAPI app, you can use relative path.
REACT_APP_API_BASE=/api/v1

# Example if API hosted separately:
# REACT_APP_API_BASE=https://api.example.com/api/v1
